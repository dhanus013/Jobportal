# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=production

# Comma-separated list of allowed origins for CORS
# In production, set this to your actual domain (e.g. https://yourdomain.com)
# For the plain HTML/CSS/JS frontend served via `npx serve -p 8080`, use:
CORS_ORIGIN=http://localhost:8080

# ============================================
# AWS Credentials
# ============================================
# NOTE: On EC2, prefer attaching an IAM Role to the instance instead of
# hardcoding keys here. If an IAM Role is attached, you can omit
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY entirely and the SDK will
# pick up credentials automatically from the instance metadata service.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAYNUBEURGDOO3K34A
AWS_SECRET_ACCESS_KEY=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

# ============================================
# Amazon S3
# ============================================
S3_BUCKET_NAME=job-portal-resumes-bucket
# Max resume upload size in bytes (default 5MB)
MAX_FILE_SIZE_BYTES=5242880

# ============================================
# Amazon DynamoDB
# ============================================
DYNAMODB_TABLE_NAME=JobApplications
